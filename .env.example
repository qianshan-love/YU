# 项目配置
PROJECT_NAME=County Chronicles Agent
VERSION=1.0.0
DEBUG=True

# 大模型配置
MODEL_BASE_URL=http://192.168.0.106:8080/v1
MODEL_NAME=Qwen3.5-35B-A3B-UD-Q4_K_XL
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096
MODEL_TIMEOUT=300

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# 数据库配置
# MongoDB
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=county_chronicles

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200
ES_INDEX_PREFIX=county_chronicles

# 任务配置
MAX_RETRIES=3
RETRY_DELAY=5
MAX_ITERATIONS=10

# 超时配置
AGENT_TIMEOUT=600
TASK_TIMEOUT=3600
REVIEW_TIMEOUT=86400

# 搜索API配置

# seesea 搜索引擎（推荐，国内可用，无需API Key）
# 安装: pip install seesea
USE_SEASEA=true                    # 是否使用 seesea（true/false）
SEASEA_DEFAULT_ENGINE=baidu       # 默认搜索引擎（baidu/bing/360/so/sogou）
SEASEA_REGION=china                # 搜索区域（china/international）

# Bing Web Search API (可选，用于真实网络搜索)
# 获取地址: https://www.microsoft.com/cognitive-services/en-us/bing-web-search-api
BING_API_KEY=your_bing_api_key_here

# Google Custom Search API (可选，用于真实网络搜索)
# 获取地址: https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
